{
  "//": "Шаблон Claude-хуков --hard. Хуки на Node (.mjs) — кросс-платформенно (Windows/macOS/Linux). install.sh/install.ps1 генерирует реальный settings с абсолютными путями к hooks/. Здесь — вариант с $CLAUDE_PROJECT_DIR для project-scope.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate-check.mjs\"" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate-bash.mjs\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-decision.mjs\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate-approve.mjs\"" }
        ]
      }
    ]
  }
}
