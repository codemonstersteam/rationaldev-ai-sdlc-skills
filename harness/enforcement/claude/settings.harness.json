{
  "//": "Шаблон Claude-хуков --hard. install.sh генерирует реальный settings с абсолютными путями к hooks/. Здесь — вариант с $CLAUDE_PROJECT_DIR для project-scope.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gate-check.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/log-decision.sh" }
        ]
      }
    ]
  }
}
