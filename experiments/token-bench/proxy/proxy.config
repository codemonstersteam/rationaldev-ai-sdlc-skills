# Конфиг token-logging прокси (источается run-proxy.sh). Правь под свой провайдер.
PORT=4000
UPSTREAM_URL=https://api.anthropic.com   # реальный провайдер; OpenAI-совм.: https://api.openai.com
PROXY_LOG=usage.jsonl                     # относительно bench/proxy/; bench.sh берёт его же
MODEL=claude-haiku-4-5                     # одна модель для обоих харнесов (метка в логе)
