# Конфиг token-logging прокси (источается run-proxy.sh). Правь под свой провайдер.
PORT=4000
UPSTREAM_URL=https://openrouter.ai        # OpenRouter (OpenAI-совм.); путь /api/v1/chat/completions форвардится как есть
PROXY_LOG=usage.jsonl                      # относительно bench/proxy/; report.sh берёт его же
MODEL=bench-openrouter                     # метка прогона; фактическая модель роли — в req_model (из тела запроса)
